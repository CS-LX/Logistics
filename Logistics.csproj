<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>annotations</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <DefineConstants>API18</DefineConstants>
    <LangVersion>preview</LangVersion>
    <AssemblyName>Logistics</AssemblyName>
    <RootNamespace>Logistics</RootNamespace>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <GenerateDependencyFile>false</GenerateDependencyFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tools\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SurvivalcraftAPI.Survivalcraft" Version="1.9.2" />
  </ItemGroup>

  <!-- monorepo 内可选：编译期引用 IE2 API；运行时由 modinfo 依赖 com.IndustrialEra2 提供，勿 copy-local。 -->
  <PropertyGroup Condition="Exists('$(MSBuildThisFileDirectory)..\..\SCIENEW\SCIENEW.csproj')">
    <DisableTransitiveProjectReferences>true</DisableTransitiveProjectReferences>
  </PropertyGroup>
  <ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\..\SCIENEW\SCIENEW.csproj')">
    <ProjectReference Include="..\..\SCIENEW\SCIENEW.csproj">
      <Private>false</Private>
      <ExcludeAssets>contentfiles</ExcludeAssets>
    </ProjectReference>
  </ItemGroup>
  <!-- ComponentEXCraftingTable 特例：与 IE2 抓取机一致，不 copy-local -->
  <ItemGroup Condition="Exists('$(MSBuildThisFileDirectory)..\..\Dependencies\RecipaediaEX\RecipaediaEX.csproj')">
    <ProjectReference Include="..\..\Dependencies\RecipaediaEX\RecipaediaEX.csproj">
      <Private>false</Private>
      <ExcludeAssets>contentfiles</ExcludeAssets>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <None Update="modinfo.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="icon.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Logistics.ier">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Logistics.csv">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Logistics.xdb">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Widgets\StorageVaultWidget.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Widgets\AdvancedInserterWidget.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Widgets\AdvancedFluidInserterWidget.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Widgets\AdvancedSorterWidget.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Models\AdvancedInserter.dae">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Models\AdvancedFluidInserter.dae">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Logistics.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Lang\zh-CN.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Lang\en-US.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Target Name="PackMod" AfterTargets="Build" Condition="'$(LogisticsSkipPack)' != 'true'">
    <PropertyGroup>
      <_TargetDirSafe>$(TargetDir.TrimEnd('\'))</_TargetDirSafe>
    </PropertyGroup>
    <Message Text="[PackMod] Target fired. TargetDir=$(_TargetDirSafe)" Importance="High" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(ProjectDir)tools\pack.ps1&quot; -BuildOutputDir &quot;$(_TargetDirSafe)&quot; -Configuration &quot;$(Configuration)&quot;" />
  </Target>
</Project>

<ChestWidget xmlns="runtime-namespace:Game">
	<!-- 左库格 | 中翻页（电容调压式 +/- + 竖滑条）| 右背包 -->
	<BevelledRectangleWidget Size="912, 382" BevelSize="3"/>
	<LabelWidget CanvasWidget.Position="16, 14" Name="VaultLabel" Text="[StorageVaultWidget:1]" Color="255, 255, 255, 192"/>
	<LabelWidget CanvasWidget.Position="608, 14" Name="InventoryLabel" Text="[StorageVaultWidget:2]" Color="255, 255, 255, 192"/>
	<GridPanelWidget CanvasWidget.Position="16, 52" Name="VaultGrid" ColumnsCount="6" RowsCount="4"/>
	<CanvasWidget CanvasWidget.Position="456, 52" Size="144, 288">

			<StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
				<BevelledButtonWidget Name="PreviousPageButton" Style="{Styles/ButtonStyle_ArrowUp}" HorizontalAlignment="Center"/>
